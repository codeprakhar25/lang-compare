---
import Layout from "../layouts/Layout.astro";
import LanguageCard from "../components/LanguageCard.astro";
import { languages, type Language } from "../data/languages";
import {
  buildWebPageSchema,
  getComparisonPath,
  getFeaturedComparisonPairs,
} from "../lib/language-seo";

const categories: Array<{ id: Language["category"] | "all"; label: string }> = [
  { id: "all", label: "All" },
  { id: "systems", label: "Systems" },
  { id: "web", label: "Web" },
  { id: "enterprise", label: "Enterprise" },
  { id: "scripting", label: "Scripting / AI" },
  { id: "general", label: "General" },
];

function tablePillClass(v: number): string {
  if (v >= 8) return "text-[var(--score-high)] bg-[var(--score-high)]/10";
  if (v >= 5) return "text-[var(--score-mid)] bg-[var(--score-mid)]/10";
  return "text-[var(--score-low)] bg-[var(--score-low)]/10";
}

const jobTableClass: Record<Language["jobMarket"], string> = {
  "very-high": "text-green-400 bg-green-400/10",
  high: "text-blue-400 bg-blue-400/10",
  medium: "text-amber-400 bg-amber-400/10",
  low: "text-red-400 bg-red-400/10",
};

const featuredPairs = getFeaturedComparisonPairs();
const pageTitle = "Compare Programming Languages with Honest Rankings";
const pageDescription =
  "Compare programming languages with real-world scoring for performance, memory, learnability, developer speed, ecosystem, concurrency, and jobs. Explore Langs Compare for Rust, Python, Go, JavaScript, TypeScript, Java, C++, and more.";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/"
  schema={buildWebPageSchema({
    title: pageTitle,
    description: pageDescription,
    path: "/",
  })}
>
  <section class="relative overflow-hidden border-b border-[var(--b1)] bg-[var(--s1)] px-8 sm:px-10 pt-16 pb-24 md:pt-20 md:pb-28">
    <div
      class="pointer-events-none absolute inset-0 opacity-[0.02]"
      style="background-image: linear-gradient(var(--b1) 1px, transparent 1px), linear-gradient(90deg, var(--b1) 1px, transparent 1px); background-size: 48px 48px;"
    />
    <div
      class="pointer-events-none absolute -right-40 bottom-0 top-1/3 w-[400px] rounded-full opacity-[0.06]"
      style="background: radial-gradient(circle, #a3e635 0%, transparent 65%)"
    />

    <div class="relative max-w-3xl mx-auto animate-fade-up">
      <p class="font-mono text-[11px] uppercase tracking-[4px] text-[var(--lime)] mb-5">
        // dev reference 2025
      </p>

      <h1 class="font-serif text-[clamp(52px,8vw,96px)] leading-[0.92] tracking-tight text-[var(--tx)] mb-6">
        Every Language.<br />
        <em class="not-italic text-[var(--lime)]">Honestly Ranked.</em>
      </h1>

      <p class="font-mono text-base text-[var(--tx3)] leading-relaxed max-w-xl mb-10">
        Compare programming languages across performance, memory, latency, ecosystem, and real-world
        tradeoffs for {languages.length} languages. Use tooltip hints on each card for practical meaning.
      </p>
      <div class="flex items-center gap-8 mb-10">
        {
          (
            [
              [String(languages.length), "Languages"],
              ["6", "Metrics Each"],
              ["Infinite", "Debates Ended"],
            ] as [string, string][]
          ).map(([num, label], i) => (
            <div
              class="flex flex-col gap-0.5 animate-fade-up"
              style={`animation-delay: ${200 + i * 80}ms`}
            >
              <span class="font-serif text-4xl text-[var(--lime)] leading-none">{num}</span>
              <span class="font-mono text-[11px] uppercase tracking-[2px] text-[var(--tx3)]">
                {label}
              </span>
            </div>
          ))
        }
      </div>

      <a
        href="/playground"
        class="
          inline-flex items-center gap-2
          font-mono text-xs uppercase tracking-[2px]
          bg-[var(--lime)] text-black px-6 py-3
          hover:bg-white transition-colors duration-200
          animate-fade-up delay-400
        "
      >
        Open Playground
        <span class="opacity-60">-&gt;</span>
      </a>
    </div>
  </section>

  <div
    class="
      sticky top-[56px] z-10
      bg-[var(--bg)] border-b border-[var(--b2)]
      shadow-[0_4px_20px_rgba(0,0,0,0.25)]
      px-6 py-3 flex flex-col gap-2
    "
  >
    <div class="flex items-center gap-3 flex-wrap">
      <span class="font-mono text-[9px] uppercase tracking-[2px] text-[var(--tx3)] w-10 shrink-0">
        Filter
      </span>
      <div id="filter-group" class="flex gap-1.5 flex-wrap">
        {
          categories.map((cat) => (
            <button
              class:list={[
                "filter-pill font-mono text-[11px] uppercase tracking-[1.5px] px-3.5 py-1.5 rounded border transition-all duration-200 cursor-pointer",
                cat.id === "all"
                  ? "bg-[var(--lime)] text-black border-[var(--lime)]"
                  : "bg-transparent text-[var(--tx3)] border-[var(--b1)] hover:border-[var(--b2)] hover:text-[var(--tx)]",
              ]}
              data-cat={cat.id}
            >
              {cat.label}
            </button>
          ))
        }
      </div>
    </div>
    <div class="hidden sm:flex items-center gap-3 flex-wrap">
      <span class="font-mono text-[9px] uppercase tracking-[2px] text-[var(--tx3)] w-10 shrink-0">
        Sort
      </span>
      <div class="flex items-center gap-1">
        {
          (
            [
              ["name", "Name"],
              ["performance", "Perf"],
              ["learnability", "Learn"],
              ["devSpeed", "Dev Spd"],
              ["ecosystem", "Ecosystem"],
            ] as [string, string][]
          ).map(([key, label]) => (
            <button
              class="sort-btn font-mono text-[11px] uppercase tracking-[1px] px-2.5 py-1 rounded text-[var(--tx3)] hover:text-[var(--lime)] transition-colors cursor-pointer"
              data-sort={key}
            >
              {label}
            </button>
          ))
        }
      </div>
      <div class="ml-auto flex items-center gap-2 border border-[var(--b2)] rounded px-3 py-1.5 bg-[var(--s2)]">
        <span class="font-mono text-xs text-[var(--lime)]">//</span>
        <input
          id="search-input"
          type="text"
          placeholder="filter..."
          autocomplete="off"
          class="bg-transparent font-mono text-xs text-[var(--tx)] placeholder:text-[var(--tx3)] outline-hidden w-44 self-stretch"
        />
      </div>
      <span
        id="result-count"
        class="font-mono text-[11px] text-[var(--tx3)] tracking-[1px]"
      >
        {languages.length} languages
      </span>
    </div>
    <!-- mobile: search + count row (visible only on xs) -->
    <div class="flex sm:hidden items-center gap-2">
      <div class="flex-1 flex items-center gap-2 border border-[var(--b2)] rounded px-3 py-3 bg-[var(--s2)]">
        <span class="font-mono text-xs text-[var(--lime)]">//</span>
        <input
          id="search-input-mobile"
          type="text"
          placeholder="filter..."
          autocomplete="off"
          class="bg-transparent font-mono text-xs text-[var(--tx)] placeholder:text-[var(--tx3)] outline-hidden w-full self-stretch"
        />
      </div>
      <span id="result-count-mobile" class="font-mono text-[11px] text-[var(--tx3)] tracking-[1px] shrink-0">
        {languages.length}
      </span>
    </div>
  </div>

  <div
    id="cards-grid"
    class="grid gap-4 p-4 sm:p-6 bg-[var(--s2)]"
    style="grid-template-columns: repeat(auto-fill, minmax(360px, 1fr))"
  >
    {languages.map((lang, i) => <LanguageCard lang={lang} index={i} />)}
  </div>

  <div
    id="grid-empty-state"
    class="hidden flex-col items-center justify-center gap-5 py-24 px-8 bg-[var(--s2)]"
  >
    <p class="font-mono text-[11px] uppercase tracking-[4px] text-[var(--tx3)]">
      // no match
    </p>
    <p class="font-mono text-sm text-[var(--tx3)] text-center max-w-xs leading-relaxed">
      No languages match your current filter or search. Try a different term or clear your selection.
    </p>
    <button
      id="clear-filters-btn"
      class="font-mono text-[11px] uppercase tracking-[1.5px] px-5 py-2.5 border border-[var(--b2)] text-[var(--tx)] hover:border-[var(--lime)] hover:text-[var(--lime)] transition-colors duration-200 rounded cursor-pointer"
    >
      Clear filters
    </button>
  </div>

  <section class="px-8 py-20 border-t border-[var(--b1)] bg-[var(--s1)]">
    <div class="max-w-6xl mx-auto">
      <div class="flex flex-col gap-3 mb-10">
        <p class="font-mono text-[11px] uppercase tracking-[4px] text-[var(--lime)]">
          // indexed comparison pages
        </p>
        <h2 class="font-serif text-5xl text-[var(--tx)]">Popular language matchups</h2>
        <p class="font-mono text-sm text-[var(--tx3)] max-w-3xl leading-relaxed">
          If you searched for terms like &quot;compare programming languages&quot;, &quot;python vs
          javascript&quot;, or &quot;rust vs go&quot;, these pages are the strongest entry points on the
          site. Each one is crawlable, canonical, and linked from the homepage.
        </p>
      </div>

      <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-3">
        {
          featuredPairs.map((pair) => (
            <a
              href={getComparisonPath(pair.left.id, pair.right.id)}
              class="border border-[var(--b1)] rounded-lg bg-[var(--s2)] p-6 hover:border-[var(--lime)] transition-colors duration-200"
            >
              <h3 class="font-serif text-3xl text-[var(--tx)] mb-3">
                {pair.left.name} vs {pair.right.name}
              </h3>
              <p class="font-mono text-sm text-[var(--tx3)] leading-relaxed mb-4">
                Compare {pair.left.name} and {pair.right.name} on runtime speed, memory profile,
                learning curve, hiring market, and where each language is strongest in production.
              </p>
              <span class="font-mono text-[11px] uppercase tracking-[2px] text-[var(--lime)]">
                Open comparison -&gt;
              </span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="px-8 py-20 border-t border-[var(--b1)]">
    <div class="mb-10">
      <h2 class="font-serif text-5xl text-[var(--tx)] mb-2">Quick Matrix</h2>
      <p class="font-mono text-[11px] uppercase tracking-[2px] text-[var(--tx3)]">
        // all languages at a glance
      </p>
    </div>

    <div class="overflow-x-auto scrollbar-thin">
      <table class="w-full border-collapse font-mono text-xs">
        <thead>
          <tr>
            {
              [
                "Language",
                "Perf",
                "Memory",
                "Learn",
                "Dev Spd",
                "Ecosystem",
                "Concurr.",
                "Type Safety",
                "Job Market",
                "Salary",
                "Paradigm",
              ].map((h) => (
                <th class="sticky top-0 text-left px-4 py-3 bg-[var(--s2)] text-[11px] uppercase tracking-[2px] text-[var(--lime)] border-b border-[var(--b2)] whitespace-nowrap">
                  {h}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            languages.map((lang) => (
              <tr class="border-b border-[var(--b1)] odd:bg-[var(--s1)] even:bg-[var(--s2)] hover:brightness-110 transition-colors duration-150 group">
                <td class="px-4 py-3 whitespace-nowrap">
                  <div class="flex items-center gap-2">
                    <span class="text-base leading-none">{lang.icon}</span>
                    <span class="text-[var(--tx)] font-medium tracking-wide">
                      {lang.name}
                    </span>
                    <span class="text-[var(--tx3)] text-[11px]">{lang.year}</span>
                  </div>
                </td>
                {
                  (
                    [
                      lang.performance,
                      lang.memoryEfficiency,
                      lang.learnability,
                      lang.devSpeed,
                      lang.ecosystem,
                      lang.concurrency,
                      lang.typeStrength,
                    ] as number[]
                  ).map((v) => (
                    <td class="px-4 py-3">
                      <span
                        class:list={[
                          "inline-block px-2.5 py-1 rounded text-[11px]",
                          tablePillClass(v),
                        ]}
                      >
                        {v}/10
                      </span>
                    </td>
                  ))
                }
                <td class="px-4 py-3">
                  <span
                    class:list={[
                      "inline-block px-2.5 py-1 rounded text-[11px]",
                      jobTableClass[lang.jobMarket],
                    ]}
                  >
                    {lang.jobMarket.replace("-", " ")}
                  </span>
                </td>
                <td class="px-4 py-3 text-[var(--tx3)] whitespace-nowrap">
                  {lang.salaryRange}
                </td>
                <td class="px-4 py-3 text-[var(--tx3)] whitespace-nowrap">
                  {lang.paradigm}
                </td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </section>

  <!-- floating compare bar -->
  <div
    id="compare-bar"
    class="fixed bottom-6 left-1/2 -translate-x-1/2 z-50 hidden items-center gap-4 px-5 py-3 rounded-lg border border-[var(--b2)] bg-[var(--s3)] shadow-[0_8px_40px_rgba(0,0,0,0.7)] animate-fade-up"
    style="min-width: 340px"
  >
    <div id="compare-bar-langs" class="flex items-center gap-3 flex-1 font-mono text-sm text-[var(--tx)]"></div>
    <a
      id="compare-bar-cta"
      href="/playground"
      class="font-mono text-[10px] uppercase tracking-[1.5px] px-4 py-2 bg-[var(--lime)] text-black rounded shrink-0 hover:bg-white transition-colors duration-150"
    >
      Compare &rarr;
    </a>
    <button
      id="compare-bar-dismiss"
      class="font-mono text-[11px] text-[var(--tx3)] hover:text-[var(--tx)] transition-colors cursor-pointer shrink-0"
      aria-label="Dismiss"
    >
      ✕
    </button>
  </div>

  <section class="border-t border-[var(--b1)] px-10 py-24 flex flex-col items-center text-center gap-6">
    <p class="font-mono text-[11px] uppercase tracking-[4px] text-[var(--lime)]">
      // side-by-side
    </p>
    <h2 class="font-serif text-5xl md:text-6xl text-[var(--tx)] leading-tight">
      Want to compare two<br /><em class="not-italic text-[var(--lime)]">head to head?</em>
    </h2>
    <p class="font-mono text-base text-[var(--tx3)] max-w-md leading-relaxed">
      Drag any two languages into the playground for radar, metric insights,
      scenario guidance, and code demos side by side.
    </p>
    <a
      href="/playground"
      class="
        font-mono text-xs uppercase tracking-[2px]
        bg-[var(--lime)] text-black px-8 py-4
        hover:bg-white transition-colors duration-200
      "
    >
      Open Playground -&gt;
    </a>
  </section>
</Layout>

<script>
  type CompareEntry = { id: string; name: string; icon: string };

  const grid = document.getElementById("cards-grid");
  const gridEmptyState = document.getElementById("grid-empty-state");
  const filterGrp = document.getElementById("filter-group");
  const searchEl = document.getElementById("search-input") as HTMLInputElement | null;
  const searchElMobile = document.getElementById("search-input-mobile") as HTMLInputElement | null;
  const countEl = document.getElementById("result-count");
  const countElMobile = document.getElementById("result-count-mobile");
  let activeCat = "all";
  let activeSearch = "";

  function getCards(): HTMLElement[] {
    return Array.from(grid?.querySelectorAll<HTMLElement>("[data-id]") || []);
  }

  function applyFilters(): void {
    let count = 0;
    getCards().forEach((card) => {
      const cat = card.dataset.category || "";
      const name = card.dataset.name || "";
      const show = (activeCat === "all" || cat === activeCat) && name.includes(activeSearch);
      card.style.display = show ? "" : "none";
      if (show) count++;
    });
    if (countEl) countEl.textContent = `${count} language${count !== 1 ? "s" : ""}`;
    if (countElMobile) countElMobile.textContent = String(count);
    if (gridEmptyState) {
      if (count === 0) {
        gridEmptyState.classList.remove("hidden");
        gridEmptyState.classList.add("flex");
      } else {
        gridEmptyState.classList.add("hidden");
        gridEmptyState.classList.remove("flex");
      }
    }
  }

  document.getElementById("clear-filters-btn")?.addEventListener("click", () => {
    activeCat = "all";
    if (searchEl) searchEl.value = "";
    if (searchElMobile) searchElMobile.value = "";
    activeSearch = "";
    filterGrp?.querySelectorAll<HTMLButtonElement>(".filter-pill").forEach((b) => {
      const isAll = b.dataset.cat === "all";
      b.classList.toggle("bg-[var(--lime)]", isAll);
      b.classList.toggle("text-black", isAll);
      b.classList.toggle("border-[var(--lime)]", isAll);
      b.classList.toggle("bg-transparent", !isAll);
      b.classList.toggle("text-[var(--tx3)]", !isAll);
      b.classList.toggle("border-[var(--b1)]", !isAll);
    });
    applyFilters();
  });

  filterGrp?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".filter-pill");
    if (!btn) return;

    activeCat = btn.dataset.cat || "all";
    filterGrp.querySelectorAll<HTMLButtonElement>(".filter-pill").forEach((b) => {
      b.classList.remove("bg-[var(--lime)]", "text-black", "border-[var(--lime)]");
      b.classList.add("bg-transparent", "text-[var(--tx3)]", "border-[var(--b1)]");
    });
    btn.classList.add("bg-[var(--lime)]", "text-black", "border-[var(--lime)]");
    btn.classList.remove("bg-transparent", "text-[var(--tx3)]", "border-[var(--b1)]");

    applyFilters();
  });

  searchEl?.addEventListener("input", () => {
    activeSearch = searchEl.value.toLowerCase().trim();
    if (searchElMobile) searchElMobile.value = searchEl.value;
    applyFilters();
  });

  searchElMobile?.addEventListener("input", () => {
    activeSearch = searchElMobile.value.toLowerCase().trim();
    if (searchEl) searchEl.value = searchElMobile.value;
    applyFilters();
  });

  const sortBtns = document.querySelectorAll<HTMLButtonElement>(".sort-btn");
  sortBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      sortBtns.forEach((b) => b.classList.remove("text-[var(--lime)]"));
      btn.classList.add("text-[var(--lime)]");

      const key = btn.dataset.sort || "name";
      const cards = getCards();

      cards.sort((a, b) => {
        const aId = a.dataset.id || "";
        const bId = b.dataset.id || "";
        if (key === "name") return aId.localeCompare(bId);
        const aVal = Number(a.dataset[key] || 0);
        const bVal = Number(b.dataset[key] || 0);
        return bVal - aVal;
      });

      cards.forEach((c) => grid?.appendChild(c));
      applyFilters();
    });
  });

  let selected: CompareEntry[] = [];
  try {
    const stored = sessionStorage.getItem("langCompare");
    if (stored) selected = JSON.parse(stored);
  } catch (_) {}

  function syncCompareBtns(): void {
    document.querySelectorAll<HTMLButtonElement>(".compare-btn").forEach((btn) => {
      const isSelected = selected.some((s) => s.id === btn.dataset.id);
      btn.textContent = isSelected ? "Selected" : "+ Compare";
      if (isSelected) {
        btn.classList.add("bg-[var(--lime)]", "text-black", "border-[var(--lime)]");
        btn.classList.remove("text-[var(--tx3)]");
      } else {
        btn.classList.remove("bg-[var(--lime)]", "text-black", "border-[var(--lime)]");
        btn.classList.add("text-[var(--tx3)]");
      }
    });
  }

  const compareBar = document.getElementById("compare-bar");
  const compareBarLangs = document.getElementById("compare-bar-langs");
  const compareBarDismiss = document.getElementById("compare-bar-dismiss");

  function syncCompareBar(): void {
    if (!compareBar || !compareBarLangs) return;
    if (selected.length === 2) {
      compareBarLangs.textContent = `${selected[0].icon} ${selected[0].name}  vs  ${selected[1].icon} ${selected[1].name}`;
      const cta = document.getElementById("compare-bar-cta") as HTMLAnchorElement | null;
      if (cta) {
        const ids = [selected[0].id, selected[1].id].sort((a, b) => a.localeCompare(b));
        cta.href = `/compare/${ids[0]}-vs-${ids[1]}`;
      }
      compareBar.classList.remove("hidden");
      compareBar.classList.add("flex");
    } else {
      compareBar.classList.add("hidden");
      compareBar.classList.remove("flex");
    }
  }

  compareBarDismiss?.addEventListener("click", () => {
    selected = [];
    sessionStorage.removeItem("langCompare");
    syncCompareBtns();
    syncCompareBar();
  });

  syncCompareBtns();
  syncCompareBar();

  grid?.addEventListener("click", (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLButtonElement>(".compare-btn");
    if (!btn) return;

    const entry: CompareEntry = {
      id: btn.dataset.id ?? "",
      name: btn.dataset.name ?? "",
      icon: btn.dataset.icon ?? "",
    };

    const idx = selected.findIndex((s) => s.id === entry.id);
    if (idx >= 0) {
      selected.splice(idx, 1);
    } else if (selected.length < 2) {
      selected.push(entry);
    } else {
      selected.shift();
      selected.push(entry);
    }

    sessionStorage.setItem("langCompare", JSON.stringify(selected));
    syncCompareBtns();
    syncCompareBar();
  });
</script>
