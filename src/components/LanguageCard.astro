---
import type { Language } from '../data/languages';

interface Props {
  lang: Language;
  index?: number;
}

const { lang, index = 0 } = Astro.props;

function scoreClass(v: number): string {
  if (v >= 8) return "score-high";
  if (v >= 5) return "score-mid";
  return "score-low";
}

const pct = (v: number) => `${v * 10}%`;

function barColor(v: number): string {
  if (v >= 8) return "#22c55e";
  if (v >= 5) return "#f59e0b";
  return "#ef4444";
}

const catClass: Record<Language["category"], string> = {
  systems:    "cat-systems",
  web:        "cat-web",
  enterprise: "cat-enterprise",
  scripting:  "cat-scripting",
  general:    "cat-general",
};

const jobClass: Record<Language["jobMarket"], string> = {
  "very-high": "job-very-high",
  high:        "job-high",
  medium:      "job-medium",
  low:         "job-low",
};

const delayMs = Math.min(index * 55, 600);

const metrics: Array<{
  label: string;
  value: number;
  tip: string;
}> = [
  { label: "Performance",   value: lang.performance,      tip: lang.tooltips.performance },
  { label: "Memory",        value: lang.memoryEfficiency,  tip: lang.tooltips.memory },
  { label: "Learnability",  value: lang.learnability,      tip: lang.tooltips.learnability },
  { label: "Dev Speed",     value: lang.devSpeed,          tip: "" },
  { label: "Ecosystem",     value: lang.ecosystem,         tip: lang.tooltips.ecosystem },
  { label: "Concurrency",   value: lang.concurrency,       tip: lang.tooltips.concurrency },
];
---

<article
  class="
    group relative flex flex-col gap-6
    bg-[var(--s1)] border border-[var(--b1)]
    hover:border-[var(--b2)] hover:bg-[var(--s2)]
    transition-all duration-300 ease-out
    animate-fade-up card-hover-glow
    overflow-hidden rounded-lg
  "
  style={`animation-delay: ${delayMs}ms`}
  data-category={lang.category}
  data-id={lang.id}
  data-name={lang.name.toLowerCase()}
  data-performance={lang.performance}
  data-learnability={lang.learnability}
  data-devSpeed={lang.devSpeed}
  data-ecosystem={lang.ecosystem}
>
  <div
    class="absolute top-0 left-0 right-0 h-px opacity-0 group-hover:opacity-100 transition-opacity duration-300"
    style={`background: linear-gradient(90deg, transparent, ${lang.color}, transparent)`}
    aria-hidden="true"
  />

  <header class="flex items-start justify-between gap-3 px-6 pt-6">
    <div class="flex items-center gap-3">
      <span class="text-3xl leading-none" role="img" aria-label={lang.name}>
        {lang.icon}
      </span>
      <div>
        <h2 class="font-serif text-2xl text-[var(--tx)] leading-none tracking-tight">
          {lang.name}
        </h2>
        <p class="font-mono text-[10px] text-[var(--tx3)] tracking-[1px] mt-1">
          {lang.year} · {lang.creator.split("/")[0].trim()}
        </p>
      </div>
    </div>

    <span
      class:list={[
        "font-mono text-[9px] tracking-[1.5px] uppercase px-2 py-1 rounded border shrink-0 mt-0.5",
        catClass[lang.category],
      ]}
    >
      {lang.categoryLabel}
    </span>
  </header>

  <div class="px-6 flex flex-col gap-2.5">
    {
      metrics.map((m) => (
        <div
          class="flex flex-col gap-1"
          data-tip={m.tip}
          title={m.tip}
        >
          <div class="flex items-center justify-between">
            <span class="font-mono text-[9px] uppercase tracking-[1.5px] text-[var(--tx3)]">
              {m.label}
            </span>
            <span class:list={["font-mono text-[10px] font-medium", scoreClass(m.value)]}>
              {m.value}/10
            </span>
          </div>

          <div class="h-[3px] w-full bg-[var(--s4)] rounded-full overflow-hidden">
            <div
              class="h-full rounded-full animate-bar-grow"
              style={`width: ${pct(m.value)}; background: ${barColor(m.value)}; animation-delay: ${delayMs + 200}ms`}
            />
          </div>
        </div>
      ))
    }
  </div>

  <div class="mx-6 border border-[var(--b1)] rounded p-3 flex flex-col gap-1.5 bg-[var(--s3)]/40">
    {
      (
        [
          ["Latency", lang.latency, lang.tooltips.latency],
          ["GC",      lang.gcModel, ""],
          ["Typing",  lang.typing,  ""],
        ] as [string, string, string][]
      ).map(([label, val, tip]) => (
        <div
          class="flex gap-2 items-baseline"
          data-tip={tip || undefined}
        >
          <span class="font-mono text-[8px] uppercase tracking-[1px] text-[var(--tx3)] w-12 shrink-0">
            {label}
          </span>
          <span class="font-mono text-[10px] text-[var(--tx2)] leading-snug">
            {val}
          </span>
        </div>
      ))
    }
  </div>

  <div class="px-6 grid grid-cols-2 gap-5">
    <div>
      <p class="font-mono text-[8px] uppercase tracking-[2px] text-[var(--tx3)] mb-2.5">
        ▲ strengths
      </p>
      <ul class="flex flex-col gap-2">
        {
          lang.pros.slice(0, 4).map((pro) => (
            <li class="flex gap-2.5 items-start">
              <span
                class="mt-[6px] size-[5px] rounded-full shrink-0 bg-[#22c55e]"
                aria-hidden="true"
              />
              <span class="font-mono text-[11px] text-[var(--tx2)] leading-relaxed">
                {pro}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <p class="font-mono text-[8px] uppercase tracking-[2px] text-[var(--tx3)] mb-2.5">
        ▼ weaknesses
      </p>
      <ul class="flex flex-col gap-2">
        {
          lang.cons.slice(0, 4).map((con) => (
            <li class="flex gap-2.5 items-start">
              <span
                class="mt-[6px] size-[5px] rounded-full shrink-0 bg-[#ef4444]"
                aria-hidden="true"
              />
              <span class="font-mono text-[11px] text-[var(--tx2)] leading-relaxed">
                {con}
              </span>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <div class="px-6">
    <p class="font-mono text-[8px] uppercase tracking-[2px] text-[var(--tx3)] mb-2">
      // used for
    </p>
    <div class="flex flex-wrap gap-1.5">
      {
        lang.useCases.slice(0, 5).map((uc) => (
          <span class="font-mono text-[9px] px-2 py-0.5 rounded bg-[rgba(163,230,53,0.06)] border border-[rgba(163,230,53,0.12)] text-[var(--lime-dim)] tracking-[0.3px]">
            {uc}
          </span>
        ))
      }
    </div>
  </div>

  <blockquote class="mx-6 border-l-2 border-[var(--b2)] pl-3 font-serif italic text-[11px] text-[var(--tx3)] leading-relaxed">
    {lang.verdict}
  </blockquote>

  <footer
    class="
      mt-auto px-6 pb-6 pt-4
      border-t border-[var(--b1)]
      flex items-center gap-4
    "
  >
    <div class="flex flex-col gap-0.5">
      <span class="font-mono text-[8px] uppercase tracking-[1px] text-[var(--tx3)]">
        Jobs
      </span>
      <span
        class:list={[
          "font-mono text-[9px] px-2 py-0.5 rounded",
          jobClass[lang.jobMarket],
        ]}
      >
        {lang.jobMarket.replace("-", " ")}
      </span>
    </div>

    <div class="flex flex-col gap-0.5">
      <span class="font-mono text-[8px] uppercase tracking-[1px] text-[var(--tx3)]">
        Salary
      </span>
      <span class="font-mono text-[10px] text-[var(--tx2)]">
        {lang.salaryRange}
      </span>
    </div>

    <button
      class="
        ml-auto font-mono text-[9px] uppercase tracking-[1.5px]
        px-3 py-1.5 rounded border border-[var(--b2)]
        text-[var(--tx3)] hover:text-black hover:bg-[var(--lime)] hover:border-[var(--lime)]
        transition-all duration-200 cursor-pointer
        compare-btn
      "
      data-id={lang.id}
      data-name={lang.name}
      data-icon={lang.icon}
      aria-label={`Compare ${lang.name}`}
    >
      + Compare
    </button>
  </footer>
</article>